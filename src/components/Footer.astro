</footer>

<style>
  #site-footer {
    background: var(--charcoal);
    color: rgba(255,255,255,0.75);
    padding: 0;
    margin-top: 0;
  }

  /* Top decorative rule */
  .footer-rule {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0 2rem;
    height: 1px;
    background: transparent;
    overflow: visible;
    position: relative;
    top: 0;
    margin-bottom: 0;
  }
  .rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .rule-ornament {
    color: var(--gold);
    font-size: 1rem;
    line-height: 1;
    display: block;
    padding: 0 0.5rem;
    position: relative;
    top: -1px;
  }

  .footer-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  /* Quote */
  .footer-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.35rem;
    color: rgba(255,255,255,0.9);
    border: none;
    padding: 0;
    margin: 0;
    line-height: 1.6;
    position: relative;
  }
  .footer-quote::before {
    content: '"';
    font-size: 4rem;
    color: var(--gold);
    opacity: 0.4;
    position: absolute;
    top: -1.5rem;
    left: -1rem;
    font-family: var(--font-display);
    line-height: 1;
  }

  /* Brand */
  .footer-brand { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .brand-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .brand-icon   { color: var(--gold); font-size: 1rem; }
  .brand-name   {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
  }
  .brand-tagline {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  /* Nav */
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.25rem 0.5rem;
  }
  .footer-nav a {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    padding: 0.3em 0.7em;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }
  .footer-nav a:hover {
    color: var(--gold-light);
    background: rgba(255,255,255,0.06);
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: 0.75rem;
  }
  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: all 0.25s ease;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .footer-social a:hover {
    background: var(--gold);
    color: var(--charcoal);
    border-color: var(--gold);
    transform: translateY(-3px);
  }

  /* Bottom bar */
  .footer-bottom {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    font-size: 0.82rem;
    color: rgba(255,255,255,0.35);
  }

  .back-to-top {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.55);
    font-size: 0.82rem;
    padding: 0.45em 1em;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: var(--font-body);
  }
  .back-to-top:hover {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--charcoal);
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .footer-quote { font-size: 1.1rem; }
    .footer-inner { padding: 3rem 1.5rem 2rem; gap: 1.5rem; }
    .footer-bottom { flex-direction: column; align-items: center; text-align: center; }
  }
</style>
