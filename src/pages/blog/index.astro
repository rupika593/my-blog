---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import blogPlaceholder1 from '../../assets/blog-placeholder-1.jpg';
import blogPlaceholder2 from '../../assets/blog-placeholder-2.jpg';
import blogPlaceholder3 from '../../assets/blog-placeholder-3.jpg';
import blogPlaceholder4 from '../../assets/blog-placeholder-4.jpg';
import blogPlaceholder5 from '../../assets/blog-placeholder-5.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ============================================
			   THE POLYMATH JOURNEY - Premium Interactive Blog
			   Where Ancient Wisdom Meets Future Intelligence
			   ============================================ */

			/* Color Palette */
			:root {
				--royal-blue: #2563EB;
				--deep-navy: #0F172A;
				--midnight-blue: #111827;
				--gold: #D4AF37;
				--accent-cyan: #06B6D4;
				--soft-white: #F8FAFC;
				--light-blue: #60A5FA;
			}

			/* Premium Animated Background */
			body {
				background: linear-gradient(135deg, #0F172A 0%, #1E3A8A 30%, #2563EB 60%, #60A5FA 100%);
				min-height: 100vh;
				position: relative;
				overflow-x: hidden;
			}

			/* Animated Starfield Background */
			body::before {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background-image: 
					radial-gradient(2px 2px at 20px 30px, rgba(255, 255, 255, 0.9), transparent),
					radial-gradient(2px 2px at 40px 70px, rgba(96, 165, 250, 0.8), transparent),
					radial-gradient(1px 1px at 90px 40px, rgba(255, 255, 255, 0.7), transparent),
					radial-gradient(2px 2px at 130px 80px, rgba(6, 182, 212, 0.9), transparent),
					radial-gradient(1px 1px at 160px 120px, rgba(255, 255, 255, 0.6), transparent),
					radial-gradient(2px 2px at 200px 50px, rgba(212, 175, 55, 0.8), transparent),
					radial-gradient(circle at 20% 30%, rgba(96, 165, 250, 0.15) 0%, transparent 50%),
					radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.15) 0%, transparent 50%),
					radial-gradient(circle at 40% 80%, rgba(37, 99, 235, 0.1) 0%, transparent 50%),
					radial-gradient(circle at 60% 20%, rgba(212, 175, 55, 0.08) 0%, transparent 40%);
				background-size: 250px 250px, 350px 350px, 150px 150px, 300px 300px;
				animation: twinkle 10s ease-in-out infinite;
				pointer-events: none;
				z-index: 0;
			}

			@keyframes twinkle {
				0%, 100% { opacity: 1; }
				50% { opacity: 0.7; }
			}

			/* Sacred Geometry Patterns */
			body::after {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background-image: 
					linear-gradient(30deg, rgba(212, 175, 55, 0.03) 12%, transparent 12.5%, transparent 87%, rgba(212, 175, 55, 0.03) 87.5%, rgba(212, 175, 55, 0.03)),
					linear-gradient(150deg, rgba(212, 175, 55, 0.03) 12%, transparent 12.5%, transparent 87%, rgba(212, 175, 55, 0.03) 87.5%, rgba(212, 175, 55, 0.03)),
					linear-gradient(30deg, rgba(212, 175, 55, 0.03) 12%, transparent 12.5%, transparent 87%, rgba(212, 175, 55, 0.03) 87.5%, rgba(212, 175, 55, 0.03)),
					linear-gradient(150deg, rgba(212, 175, 55, 0.03) 12%, transparent 12.5%, transparent 87%, rgba(212, 175, 55, 0.03) 87.5%, rgba(212, 175, 55, 0.03));
				background-size: 100px 100px;
				background-position: 0 0, 0 0, 50px 50px, 50px 50px;
				pointer-events: none;
				z-index: 0;
			}

			main {
				width: 1400px;
				max-width: calc(100% - 2em);
				position: relative;
				z-index: 1;
			}

			/* Premium Hero Section */
			.blog-hero {
				text-align: center;
				padding: 6rem 3rem;
				background: linear-gradient(135deg, rgba(15, 23, 42, 0.8) 0%, rgba(37, 99, 235, 0.6) 50%, rgba(6, 182, 212, 0.4) 100%);
				backdrop-filter: blur(30px);
				border-radius: 32px;
				margin-bottom: 4rem;
				border: 2px solid rgba(212, 175, 55, 0.3);
				box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), inset 0 0 60px rgba(212, 175, 55, 0.1);
				animation: fadeInDown 1s ease-out;
				position: relative;
				overflow: hidden;
			}

			.blog-hero::before {
				content: '';
				position: absolute;
				top: -50%;
				left: -50%;
				width: 200%;
				height: 200%;
				background: radial-gradient(circle, rgba(212, 175, 55, 0.1) 0%, transparent 70%);
				animation: rotate 30s linear infinite;
			}

			@keyframes rotate {
				0% { transform: rotate(0deg); }
				100% { transform: rotate(360deg); }
			}

			.blog-hero h1 {
				font-size: 4.5rem;
				background: linear-gradient(135deg, #D4AF37 0%, #FFFFFF 50%, #60A5FA 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				margin-bottom: 1.5rem;
				font-weight: 900;
				position: relative;
				z-index: 1;
				text-shadow: 0 0 40px rgba(212, 175, 55, 0.5);
			}

			.blog-hero .subtitle {
				font-size: 1.4rem;
				color: rgba(255, 255, 255, 0.95);
				line-height: 2;
				margin-bottom: 1.5rem;
				position: relative;
				z-index: 1;
				font-weight: 300;
			}

			.blog-hero .tagline {
				font-size: 1.1rem;
				color: rgba(212, 175, 55, 0.9);
				font-style: italic;
				position: relative;
				z-index: 1;
			}

			/* Animated Timeline Navigation */
			.timeline-nav {
				display: flex;
				justify-content: center;
				gap: 1rem;
				margin-bottom: 4rem;
				padding: 1.5rem;
				background: rgba(15, 23, 42, 0.6);
				backdrop-filter: blur(20px);
				border-radius: 24px;
				border: 1px solid rgba(212, 175, 55, 0.2);
				animation: fadeInUp 1s ease-out 0.3s both;
				flex-wrap: wrap;
			}

			.timeline-step {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				padding: 0.8rem 1.5rem;
				background: rgba(255, 255, 255, 0.05);
				border-radius: 50px;
				border: 1px solid rgba(212, 175, 55, 0.2);
				color: white;
				font-weight: 600;
				font-size: 0.9rem;
				transition: all 0.3s ease;
				cursor: pointer;
			}

			.timeline-step:hover {
				background: linear-gradient(135deg, rgba(37, 99, 235, 0.3), rgba(6, 182, 212, 0.3));
				border-color: var(--gold);
				transform: translateY(-3px);
				box-shadow: 0 8px 20px rgba(212, 175, 55, 0.3);
			}

			.timeline-step.active {
				background: linear-gradient(135deg, var(--royal-blue), var(--accent-cyan));
				border-color: var(--gold);
			}

			.timeline-step .icon {
				font-size: 1.3rem;
			}

			/* Premium Articles Grid */
			.articles-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
				gap: 3rem;
				margin-top: 3rem;
			}

			.article-card {
				background: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(37, 99, 235, 0.9) 100%);
				backdrop-filter: blur(30px);
				border-radius: 24px;
				overflow: hidden;
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(6, 182, 212, 0.2);
				transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
				animation: fadeInUp 1s ease-out;
				border: 2px solid rgba(212, 175, 55, 0.2);
				position: relative;
			}

			.article-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				border-radius: 24px;
				padding: 2px;
				background: linear-gradient(135deg, var(--gold), var(--accent-cyan), var(--royal-blue));
				-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
				-webkit-mask-composite: xor;
				mask-composite: exclude;
				opacity: 0;
				transition: opacity 0.5s ease;
			}

			.article-card:hover {
				transform: translateY(-15px) scale(1.03);
				box-shadow: 0 30px 80px rgba(37, 99, 235, 0.4), 0 0 50px rgba(212, 175, 55, 0.3);
			}

			.article-card:hover::before {
				opacity: 1;
			}

			.article-hero {
				position: relative;
				width: 100%;
				overflow: hidden;
			}

			.article-hero img {
				width: 100%;
				height: 240px;
				object-fit: cover;
				transition: all 0.6s ease;
				filter: brightness(0.9);
			}

			.article-card:hover .article-hero img {
				transform: scale(1.1);
				filter: brightness(1.1);
			}

			.article-hero::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				height: 100%;
				background: linear-gradient(to top, rgba(15, 23, 42, 0.9) 0%, transparent 100%);
				pointer-events: none;
			}

			.article-content {
				padding: 2.5rem;
				background: linear-gradient(135deg, rgba(15, 23, 42, 0.98) 0%, rgba(30, 58, 138, 0.95) 100%);
			}

			.article-meta {
				display: flex;
				gap: 1rem;
				margin-bottom: 1.2rem;
				font-size: 0.85rem;
				align-items: center;
				flex-wrap: wrap;
			}

			.article-date {
				color: var(--gold);
				font-weight: 700;
				background: rgba(212, 175, 55, 0.15);
				padding: 0.5rem 1rem;
				border-radius: 20px;
				border: 1px solid rgba(212, 175, 55, 0.3);
			}

			.reading-time {
				color: var(--accent-cyan);
				font-weight: 700;
				background: rgba(6, 182, 212, 0.15);
				padding: 0.5rem 1rem;
				border-radius: 20px;
				display: flex;
				align-items: center;
				gap: 0.4rem;
				border: 1px solid rgba(6, 182, 212, 0.3);
			}

			.article-title {
				font-size: 2rem;
				margin: 0 0 1.2rem 0;
				background: linear-gradient(135deg, #D4AF37 0%, #FFFFFF 50%, #60A5FA 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				line-height: 1.3;
				font-weight: 800;
				transition: all 0.3s ease;
			}

			.article-card:hover .article-title {
				background: linear-gradient(135deg, #60A5FA 0%, #D4AF37 50%, #FFFFFF 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}

			.article-preview {
				color: rgba(255, 255, 255, 0.85);
				line-height: 1.9;
				font-size: 1.05rem;
				margin-bottom: 1.8rem;
				display: -webkit-box;
				-webkit-line-clamp: 4;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.explore-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.7rem;
				padding: 1rem 2.2rem;
				background: linear-gradient(135deg, var(--royal-blue) 0%, var(--midnight-blue) 100%);
				color: white;
				text-decoration: none;
				border-radius: 50px;
				font-weight: 700;
				font-size: 1rem;
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				box-shadow: 0 8px 25px rgba(37, 99, 235, 0.5), 0 0 15px rgba(212, 175, 55, 0.3);
				position: relative;
				overflow: hidden;
				border: 2px solid rgba(212, 175, 55, 0.3);
			}

			.explore-btn::before {
				content: '';
				position: absolute;
				top: 0;
				left: -100%;
				width: 100%;
				height: 100%;
				background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
				transition: left 0.6s ease;
			}

			.explore-btn:hover::before {
				left: 100%;
			}

			.explore-btn:hover {
				transform: translateY(-4px) translateX(5px);
				box-shadow: 0 15px 40px rgba(37, 99, 235, 0.6), 0 0 30px rgba(212, 175, 55, 0.5);
				border-color: var(--gold);
			}

			.explore-btn svg {
				transition: transform 0.3s ease;
			}

			.explore-btn:hover svg {
				transform: translateX(6px);
			}

			/* Animations */
			@keyframes fadeInUp {
				from {
					opacity: 0;
					transform: translateY(50px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes fadeInDown {
				from {
					opacity: 0;
					transform: translateY(-50px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			/* Responsive Design */
			@media (max-width: 1200px) {
				.articles-grid {
					grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
				}
			}

			@media (max-width: 960px) {
				.articles-grid {
					grid-template-columns: 1fr;
				}

				.blog-hero h1 {
					font-size: 3rem;
				}

				.blog-hero .subtitle {
					font-size: 1.1rem;
				}

				.timeline-nav {
					gap: 0.5rem;
				}

				.timeline-step {
					padding: 0.6rem 1rem;
					font-size: 0.85rem;
				}
			}

			@media (max-width: 480px) {
				.article-content {
					padding: 1.8rem;
				}

				.article-title {
					font-size: 1.6rem;
				}

				.article-preview {
					font-size: 0.95rem;
				}

				.explore-btn {
					width: 100%;
					justify-content: center;
				}

				.blog-hero {
					padding: 3rem 1.5rem;
				}

				.blog-hero h1 {
					font-size: 2.2rem;
				}

				.blog-hero .subtitle {
					font-size: 1rem;
				}

				.timeline-step {
					flex: 1 1 100%;
					justify-content: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-hero">
				<h1>The Polymath Journey</h1>
				<p class="subtitle">
					Welcome to my personal blog, where I share my journey of learning, exploration, and growth. From ancient wisdom to modern technology, join me as I explore the intersections of tradition and innovation.
				</p>
				<p class="tagline">
					<em>Where Ancient Wisdom Meets Future Intelligence</em>
				</p>
			</div>

			<!-- Animated Timeline Navigation -->
			<nav class="timeline-nav">
				<div class="timeline-step active">
					<span class="icon">🏛</span>
					<span>Inception</span>
				</div>
				<div class="timeline-step">
					<span class="icon">🎓</span>
					<span>Next Chapter</span>
				</div>
				<div class="timeline-step">
					<span class="icon">💡</span>
					<span>Awakening</span>
				</div>
				<div class="timeline-step">
					<span class="icon">🚀</span>
					<span>Exploration</span>
				</div>
				<div class="timeline-step">
					<span class="icon">🌟</span>
					<span>Dream Goals</span>
				</div>
			</nav>
			
			<!-- Story Articles Grid -->
			<section class="articles-grid">
				<!-- Article 1: Inception -->
				<article class="article-card">
					<div class="article-hero">
						<Image width={600} height={300} src={blogPlaceholder1} alt="Inception" />
					</div>
					<div class="article-content">
						<div class="article-meta">
							<span class="article-date">Jan 15 2024</span>
							<span class="reading-time">4 min read</span>
						</div>
						<h2 class="article-title">Inception</h2>
						<p class="article-preview">
							I started my schooling in a spirituality-based school where I learned about our history, culture, discipline, and integrity. My teachers inspired me to explore the stories of the Mahabharata and Ramayana, and introduced me to the timeless wisdom of the Bhagavad Gita.
						</p>
						<a href="/blog/article-1-inception" class="explore-btn">
							<span>Explore More</span>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M5 12h14M12 5l7 7-7 7"/>
							</svg>
						</a>
					</div>
				</article>

				<!-- Article 2: The Next Chapter -->
				<article class="article-card">
					<div class="article-hero">
						<Image width={600} height={300} src={blogPlaceholder2} alt="The Next Chapter" />
					</div>
					<div class="article-content">
						<div class="article-meta">
							<span class="article-date">Feb 15 2024</span>
							<span class="reading-time">3 min read</span>
						</div>
						<h2 class="article-title">The Next Chapter</h2>
						<p class="article-preview">
							After completing my 10th standard, I joined Sri Chaitanya Junior College for my Intermediate education. During these two years, I learned much more than academics—I learned independence, responsibility, and how to overcome challenges.
						</p>
						<a href="/blog/article-2-next-chapter" class="explore-btn">
							<span>Explore More</span>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M5 12h14M12 5l7 7-7 7"/>
							</svg>
						</a>
					</div>
				</article>

				<!-- Article 3: Awakening -->
				<article class="article-card">
					<div class="article-hero">
						<Image width={600} height={300} src={blogPlaceholder3} alt="Awakening" />
					</div>
					<div class="article-content">
						<div class="article-meta">
							<span class="article-date">Mar 15 2024</span>
							<span class="reading-time">5 min read</span>
						</div>
						<h2 class="article-title">Awakening</h2>
						<p class="article-preview">
							After Intermediate, I did not secure a good rank in EAPCET. But by God's grace, I received admission to Visakha Institute of Engineering and Technology. Here, my curiosity about ancient temples and quantum physics awakened, alongside my passion for AI and Machine Learning.
						</p>
						<a href="/blog/article-3-awakening" class="explore-btn">
							<span>Explore More</span>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M5 12h14M12 5l7 7-7 7"/>
							</svg>
						</a>
					</div>
				</article>

				<!-- Article 4: Exploration -->
				<article class="article-card">
					<div class="article-hero">
						<Image width={600} height={300} src={blogPlaceholder4} alt="Exploration" />
					</div>
					<div class="article-content">
						<div class="article-meta">
							<span class="article-date">Apr 15 2024</span>
							<span class="reading-time">10 min read</span>
						</div>
						<h2 class="article-title">Exploration</h2>
						<p class="article-preview">
							My third year of engineering became the beginning of my skill development journey. Through guidance, curiosity, and continuous learning, I explored Agentic AI, modern development tools, Artificial Intelligence, Indian Knowledge Systems, blockchain, quantum physics, and real-world project building.
						</p>
						<a href="/blog/article-4-exploration" class="explore-btn">
							<span>Explore More</span>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M5 12h14M12 5l7 7-7 7"/>
							</svg>
						</a>
					</div>
				</article>

				<!-- Article 5: Dream Goals -->
				<article class="article-card">
					<div class="article-hero">
						<Image width={600} height={300} src={blogPlaceholder5} alt="Dream Goals" />
					</div>
					<div class="article-content">
						<div class="article-meta">
							<span class="article-date">May 15 2024</span>
							<span class="reading-time">3 min read</span>
						</div>
						<h2 class="article-title">Dream Goals</h2>
						<p class="article-preview">
							My long-term aspiration is to build a successful career in technology while continuing to explore psychology, philosophy, archaeology, ancient temples, astrophysics, public service, and lifelong learning. Learning never ends.
						</p>
						<a href="/blog/article-5-dream-goals" class="explore-btn">
							<span>Explore More</span>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M5 12h14M12 5l7 7-7 7"/>
							</svg>
						</a>
					</div>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>
