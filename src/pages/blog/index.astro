---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import aiCardImage from '../../assets/ai-card.jpg';
import templeCardImage from '../../assets/temple-card.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
			ul.featured-grid li {
				width: calc(50% - 1rem);
				text-align: left;
			}
			ul.featured-grid li img {
				width: 100%;
			}
			.read-more-btn {
				display: inline-block;
				margin-top: 1rem;
				font-size: 0.95rem;
				font-weight: 600;
				color: rgb(var(--accent));
				transition: transform 0.2s ease;
			}
			ul.featured-grid li a:hover .read-more-btn {
				transform: translateX(4px);
			}
			@media (max-width: 720px) {
				ul.featured-grid li {
					width: 100%;
					text-align: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div style="margin-bottom: 2rem;">
				<h1 style="margin-bottom: 0.5rem;">Exploring AI & Ancient Temples</h1>
				<p style="color: rgb(var(--gray-dark)); font-size: 1.1rem; line-height: 1.6;">
					Welcome to my blog, where technology meets history. I share insights into <strong>Artificial Intelligence</strong>, exploring how it is transforming the future through smart innovations, while also uncovering the beauty and history of <strong>ancient temples</strong>, celebrating India's rich cultural and architectural heritage. Join me as we discover the perfect blend of innovation and tradition.
				</p>
			</div>
			<section>
				<ul class="featured-grid">
					<li>
						<a href="/blog/ai">
							<Image width={720} height={360} src={aiCardImage} alt="Artificial Intelligence" />
							<h4 class="title">Artificial Intelligence</h4>
							<p style="color: rgb(var(--gray)); margin-top: 0.5rem; line-height: 1.5;">
								Explore beginner-friendly AI concepts, machine learning, and the latest innovations shaping the future.
							</p>
							<span class="read-more-btn">Read More &rarr;</span>
						</a>
					</li>
					<li>
						<a href="/blog/temples">
							<Image width={720} height={360} src={templeCardImage} alt="Ancient Temples" />
							<h4 class="title">Ancient Temples</h4>
							<p style="color: rgb(var(--gray)); margin-top: 0.5rem; line-height: 1.5;">
								Discover the history, architecture, and cultural significance of ancient temples and India's rich heritage.
							</p>
							<span class="read-more-btn">Read More &rarr;</span>
						</a>
					</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
