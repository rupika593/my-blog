.jcard-emoji{position:absolute;top:1rem;left:1rem;background:rgba(201,168,76,.9);color:#fff;width:2.4rem;height:2.4rem;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;}
.jcard-body{padding:1.8rem;}
.jcard-meta{display:flex;gap:1rem;margin-bottom:.8rem;}
.jcard-date{font-size:.8rem;font-weight:600;color:var(--gold-light);background:rgba(201,168,76,.15);padding:.3em .8em;border-radius:20px;border:1px solid rgba(201,168,76,.25);}
.jcard-read{font-size:.8rem;color:rgba(255,255,255,.5);}
.jcard-title{font-family:var(--font-display);font-size:1.6rem;font-weight:700;color:#fff;margin:0 0 .8rem;line-height:1.25;}
.jcard-prev{color:rgba(255,255,255,.7);font-size:.95rem;line-height:1.7;margin-bottom:1.4rem;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden;}
.jcard-btn{font-size:.9rem;padding:.75em 1.6em;}
.journey-cta{margin-top:3rem;padding-bottom:1rem;}
</style>

<style>
/* ── TIMELINE ── */
.s-timeline{background:var(--ivory);padding:0;}
.timeline{list-style:none;padding:0;margin:0;position:relative;display:flex;flex-direction:column;gap:0;}
.timeline::before{content:'';position:absolute;top:0;bottom:0;left:50%;width:2px;background:linear-gradient(180deg,transparent,var(--gold),var(--gold),transparent);transform:translateX(-50%);}
.tl-item{display:grid;grid-template-columns:1fr 60px 1fr;align-items:start;gap:0;padding:1.5rem 0;}
.tl-item:nth-child(odd) .tl-content{grid-column:1;grid-row:1;text-align:right;padding-right:2.5rem;}
.tl-item:nth-child(odd) .tl-marker{grid-column:2;grid-row:1;}
.tl-item:nth-child(even) .tl-content{grid-column:3;grid-row:1;text-align:left;padding-left:2.5rem;}
.tl-item:nth-child(even) .tl-marker{grid-column:2;grid-row:1;}
.tl-marker{display:flex;align-items:center;justify-content:center;position:relative;z-index:2;padding-top:.5rem;}
.tl-icon{width:46px;height:46px;background:linear-gradient(135deg,var(--gold-dark),var(--gold));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.3rem;box-shadow:0 0 0 4px var(--ivory),0 0 0 6px rgba(201,168,76,.3);}
.tl-content{padding:1.4rem 1.6rem;}
.tl-year{font-size:.75rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-dark);}
.tl-title{font-family:var(--font-display);font-size:1.25rem;color:var(--charcoal);margin:.3rem 0 .5rem;}
.tl-desc{font-size:.9rem;color:var(--slate);line-height:1.7;margin:0;}

/* ── PLATFORMS ── */
.s-platforms{background:var(--cream);padding:0;}
.platforms-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.25rem;text-align:left;}
.pcard{background:rgba(255,254,249,.8);border:1px solid rgba(201,168,76,.15);border-radius:var(--card-radius);padding:1.5rem;cursor:pointer;text-align:left;transition:all .3s var(--ease-out);}
.pcard:hover{transform:translateY(-6px);box-shadow:0 12px 36px rgba(0,0,0,.1),0 0 0 2px rgba(201,168,76,.35);}
.pcard-icon{font-size:2rem;display:block;margin-bottom:.8rem;}
.pcard-name{font-family:var(--font-body);font-size:1rem;font-weight:700;color:var(--charcoal);display:block;margin-bottom:.5rem;}
.pcard-desc{font-size:.82rem;color:var(--slate);line-height:1.6;margin:0 0 .8rem;}
.pcard-badge{font-size:.72rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--gold-dark);background:rgba(201,168,76,.12);border:1px solid rgba(201,168,76,.25);padding:.25em .7em;border-radius:20px;}

/* ── TECHNOLOGIES ── */
.s-tech{background:var(--warm-white);padding:0;}
.tech-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:1.25rem;text-align:left;}
.tcard{padding:1.4rem;}
.tcard-icon{font-size:1.8rem;display:block;margin-bottom:.7rem;}
.tcard-title{font-size:.95rem;font-weight:700;color:var(--charcoal);display:block;margin-bottom:.4rem;}
.tcard-desc{font-size:.82rem;color:var(--slate);line-height:1.6;margin:0;}
</style>

<style>
/* ── MOVIES & ANIME ── */
.s-movies{background:var(--charcoal-mid);padding:0;}
.s-anime{background:var(--charcoal);padding:0;}
.s-movies .section-title,.s-anime .section-title{color:#fff;}
.s-movies .section-desc,.s-anime .section-desc{color:rgba(255,255,255,.7);}
.media-gallery{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1.5rem;margin-top:1rem;}
.media-gallery--sm{grid-template-columns:repeat(auto-fill,minmax(220px,1fr));}
.mcard{background:rgba(255,255,255,.06);border:1px solid rgba(201,168,76,.15);border-radius:16px;padding:1.4rem 1.2rem;cursor:pointer;text-align:center;transition:all .35s var(--ease-out);display:flex;flex-direction:column;align-items:center;gap:.5rem;}
.mcard:hover{transform:translateY(-8px);background:rgba(201,168,76,.1);border-color:rgba(201,168,76,.45);box-shadow:0 12px 36px rgba(0,0,0,.3);}
.mcard-poster{width:80px;height:120px;border-radius:10px;background:linear-gradient(135deg,rgba(201,168,76,.25),rgba(201,168,76,.1));display:flex;align-items:center;justify-content:center;border:1px solid rgba(201,168,76,.25);margin-bottom:.5rem;}
.mcard-emoji{font-size:2.5rem;line-height:1;}
.mcard-title{font-family:var(--font-display);font-size:.95rem;font-weight:700;color:#fff;line-height:1.3;}
.mcard-year{font-size:.75rem;color:var(--gold-light);font-weight:600;}
.mcard-insight{font-size:.8rem;color:rgba(255,255,255,.6);line-height:1.5;margin:0;}

/* ── SKILLS ── */
.s-skills{background:var(--ivory);padding:0;}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;text-align:left;}
.skill-card{padding:1.2rem 1.4rem;}
.skill-top{display:flex;align-items:center;gap:.6rem;margin-bottom:.8rem;}
.skill-icon{font-size:1.3rem;width:2rem;text-align:center;}
.skill-name{flex:1;font-size:.9rem;font-weight:700;color:var(--charcoal);}
.skill-pct{font-size:.82rem;font-weight:700;color:var(--gold-dark);}
.skill-bar{height:6px;background:var(--parchment);border-radius:3px;overflow:hidden;}
.skill-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--gold-dark),var(--gold-light));width:0;transition:width 1.2s var(--ease-out);}
.skill-fill.animated{width:var(--pct);}

/* ── CONTACT ── */
.s-contact{background:var(--cream);padding:0;}
.contact-cards{display:flex;flex-wrap:wrap;gap:1.5rem;justify-content:center;margin-top:1rem;}
.contact-card{display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:2rem 2.5rem;text-decoration:none;color:var(--ink);min-width:180px;transition:all .3s var(--ease-out);}
.contact-card:hover{color:var(--gold-dark);}
.cc-icon{font-size:2rem;}
.contact-card strong{font-size:1rem;font-weight:700;color:var(--charcoal);}
.contact-card span{font-size:.85rem;color:var(--slate);}

/* ── MODAL INNER STYLES ── */
.modal-icon{font-size:3rem;display:block;margin-bottom:1rem;text-align:center;}
.modal-title{font-family:var(--font-display);font-size:1.6rem;color:var(--charcoal);margin:0 0 1rem;text-align:center;}
.modal-desc{color:var(--slate);line-height:1.7;font-size:.95rem;margin-bottom:1.2rem;}
.modal-experience-label{font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gold-dark);margin:1.2rem 0 .4rem;}
.modal-exp{color:var(--ink);font-size:.95rem;line-height:1.7;margin:0;}
.modal-btn{width:100%;justify-content:center;margin-top:1.5rem;}
.mm-poster{width:120px;height:180px;border-radius:12px;background:linear-gradient(135deg,rgba(201,168,76,.2),rgba(201,168,76,.05));display:flex;align-items:center;justify-content:center;border:1px solid rgba(201,168,76,.3);margin:0 auto 1rem;font-size:3.5rem;}
.mm-year{display:block;text-align:center;font-size:.8rem;font-weight:700;color:var(--gold-dark);margin-bottom:.5rem;letter-spacing:.08em;}

/* ── Responsive ── */
@media(max-width:900px){
  .timeline::before{left:28px;}
  .tl-item{grid-template-columns:56px 1fr;gap:0;}
  .tl-item:nth-child(odd) .tl-content,.tl-item:nth-child(even) .tl-content{grid-column:2;grid-row:1;text-align:left;padding:1rem 0 1rem 1.5rem;}
  .tl-item:nth-child(odd) .tl-marker,.tl-item:nth-child(even) .tl-marker{grid-column:1;grid-row:1;}
  .journey-cards{grid-template-columns:1fr;}
  .jcard--featured{grid-column:auto;}
}
@media(max-width:600px){
  .interests-grid,.platforms-grid,.tech-grid,.media-gallery,.skills-grid{grid-template-columns:1fr;}
  .hero-btns{flex-direction:column;align-items:center;}
  .contact-cards{flex-direction:column;align-items:center;}
}
</style>

<script>
// ── Scroll Reveal ──
const revealEls = document.querySelectorAll('.reveal,.reveal-left,.reveal-right');
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
}, { threshold: 0.12 });
revealEls.forEach(el => revealObs.observe(el));

// ── Skill bar animation ──
const skillFills = document.querySelectorAll('.skill-fill');
const skillObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('animated'); skillObs.unobserve(e.target); } });
}, { threshold: 0.3 });
skillFills.forEach(el => skillObs.observe(el));

// ── Platform data ──
const platformData = {
  replit:    { icon:'💻', name:'Replit',          url:'https://replit.com',       exp:'I used Replit to build and test my first web projects directly from the browser, which helped me understand deployment and live coding without any setup.' },
  github:    { icon:'🐙', name:'GitHub',          url:'https://github.com',       exp:'GitHub became my digital portfolio. I learned version control, collaboration, and how to manage projects professionally.' },
  kiro:      { icon:'🤖', name:'Kiro IDE',        url:'https://kiro.dev',         exp:'Kiro IDE transformed how I write code. Its AI-powered suggestions helped me understand structure, debugging, and modern development practices.' },
  cursor:    { icon:'✨', name:'Cursor',          url:'https://cursor.sh',        exp:'Cursor accelerated my coding by providing intelligent completions and explanations that helped me learn faster.' },
  antigrav:  { icon:'🚀', name:'Antigravity',     url:'#',                        exp:'Antigravity simplified project creation and rapid experimentation, letting me focus on ideas rather than setup.' },
  n8n:       { icon:'⚙️', name:'n8n',            url:'https://n8n.io',           exp:'I built my first AI automation workflows using n8n, connecting services and automating tasks that would otherwise require manual effort.' },
  openai:    { icon:'🧠', name:'OpenAI',          url:'https://openai.com',       exp:'OpenAI models taught me about prompting, intelligent automation, and building applications powered by advanced language understanding.' },
  gemini:    { icon:'♊', name:'Gemini',          url:'https://gemini.google.com',exp:"Google's Gemini helped me with research, coding queries, and reasoning through complex topics quickly." },
  glm:       { icon:'💬', name:'GLM',             url:'#',                        exp:'I used GLM for AI-based conversations and exploring what language models can do for application development.' },
  ollama:    { icon:'🦙', name:'Ollama',          url:'https://ollama.ai',        exp:'Ollama let me run open-source AI models locally for experimentation, which deepened my understanding of how models work under the hood.' },
  sarvam:    { icon:'🇮🇳', name:'Sarvam AI',      url:'https://sarvam.ai',        exp:'Sarvam AI introduced me to multilingual AI for Indian languages, connecting modern AI with cultural and linguistic diversity.' },
  student:   { icon:'🎓', name:'Student Chakra',  url:'https://studentchakra.in', exp:'Student Chakra provided opportunities, hackathon listings, and resources that helped me stay connected to the student tech community.' },
  hack2skill:{ icon:'🏆', name:'Hack2Skill',      url:'https://hack2skill.com',   exp:'Hack2Skill connected me to hackathons and coding competitions where I applied my learning in real, time-constrained challenges.' },
  iks:       { icon:'🕉', name:'IKS',             url:'#',                        exp:"Indian Knowledge Systems opened my eyes to the richness of India's traditional science, mathematics, and philosophy." },
  stemiks:   { icon:'🔬', name:'STEM IKS',        url:'#',                        exp:'STEM IKS bridges modern STEM education with ancient Indian knowledge, encouraging interdisciplinary and holistic learning.' },
};

// ── Media data ──
const mediaData = {
  inception:    { emoji:'🌀', title:'Inception',        year:'2010', why:'Inspired me to think about layers of reality, perception, and how ideas shape our actions. The concept of planting an idea deep inside someone\'s mind mirrors how education and stories change us.', takeaway:'Every dream is a step inside a deeper layer of thought.' },
  matrix:       { emoji:'💊', title:'The Matrix',        year:'1999', why:'Challenged me to question every assumption about the world. The idea that we may be living inside a constructed reality pushed me to explore philosophy and critical thinking.', takeaway:'The truth is only found by those willing to look beyond the surface.' },
  ironman:      { emoji:'🦾', title:'Iron Man',          year:'2008', why:'Tony Stark showed me that engineering combined with creativity can change the world. It inspired me to see technology not as a tool but as an extension of who we are.', takeaway:'Engineering is not just a skill — it is a superpower.' },
  bigshort:     { emoji:'📉', title:'The Big Short',     year:'2015', why:'Taught me to think critically about complex systems. Understanding how financial markets work — and fail — made me realise that knowledge is power and ignorance is expensive.', takeaway:'Those who understand the rules can see when they are being broken.' },
  startrek:     { emoji:'🖖', title:'Star Trek',         year:'1966', why:'Presented an optimistic vision of humanity united by curiosity, science, and collaboration. It showed me that exploring the unknown is the highest calling.', takeaway:'The final frontier is the human mind.' },
  starwars:     { emoji:'⚔️', title:'Star Wars',         year:'1977', why:"Taught me about resilience, the hero's journey, and the battle between light and darkness that exists in every person's story.", takeaway:'The force within is stronger than any circumstance without.' },
  siliconvalley:{ emoji:'💡', title:'Silicon Valley',    year:'2014', why:'Gave me a realistic and funny view of startup culture. It taught me that building something meaningful is messy, iterative, and deeply human.', takeaway:'Compression is just the beginning — find your own algorithm.' },
  fmab:         { emoji:'⚗️', title:'Fullmetal Alchemist: Brotherhood', year:'2009', why:'Showed me that true knowledge comes with responsibility. The law of equivalent exchange mirrors the real-world truth that every achievement requires sacrifice.', takeaway:'Equivalent exchange: to gain something, something of equal value must be lost.' },
  deathnote:    { emoji:'📓', title:'Death Note',        year:'2006', why:'Explored the dangerous intersection of genius and unchecked power. It made me think deeply about ethics, justice, and the responsibility that comes with intelligence.', takeaway:'Genius without conscience is a weapon without direction.' },
  avatar:       { emoji:'🌊', title:'Avatar: The Last Airbender', year:'2005', why:'Taught me that mastery requires balancing not just external skills but also the inner self. Growth means facing your fears and embracing all parts of who you are.', takeaway:'The greatest victory is the one over yourself.' },
};

// ── Platform modal ──
const pmOverlay = document.getElementById('platform-modal');
const pmClose   = document.getElementById('pm-close');
function openPlatformModal(id) {
  const d = platformData[id]; if(!d) return;
  document.getElementById('pm-icon').textContent  = d.icon;
  document.getElementById('pm-title').textContent = d.name;
  document.getElementById('pm-desc').textContent  = d.desc || '';
  document.getElementById('pm-exp').textContent   = d.exp;
  const lnk = document.getElementById('pm-link');
  lnk.href = d.url; lnk.style.display = d.url === '#' ? 'none' : 'flex';
  pmOverlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}
document.querySelectorAll('.pcard').forEach(btn => {
  btn.addEventListener('click', () => openPlatformModal(btn.dataset.platform));
});
pmClose?.addEventListener('click', closePM);
pmOverlay?.addEventListener('click', e => { if(e.target === pmOverlay) closePM(); });
function closePM(){ pmOverlay.classList.remove('open'); document.body.style.overflow=''; }

// ── Media modal ──
const mmOverlay = document.getElementById('media-modal');
const mmClose   = document.getElementById('mm-close');
function openMediaModal(id) {
  const d = mediaData[id]; if(!d) return;
  document.getElementById('mm-poster').textContent  = d.emoji;
  document.getElementById('mm-year').textContent    = d.year;
  document.getElementById('mm-title').textContent   = d.title;
  document.getElementById('mm-why').textContent     = d.why;
  document.getElementById('mm-takeaway').textContent= d.takeaway;
  mmOverlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}
document.querySelectorAll('.mcard').forEach(btn => {
  btn.addEventListener('click', () => openMediaModal(btn.dataset.media));
});
mmClose?.addEventListener('click', closeMM);
mmOverlay?.addEventListener('click', e => { if(e.target === mmOverlay) closeMM(); });
function closeMM(){ mmOverlay.classList.remove('open'); document.body.style.overflow=''; }

// Keyboard close
document.addEventListener('keydown', e => { if(e.key==='Escape'){ closePM(); closeMM(); } });
</script>

</html>
