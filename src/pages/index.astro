---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import blogImg1 from '../assets/blog-placeholder-1.jpg';
import blogImg2 from '../assets/blog-placeholder-2.jpg';
import blogImg3 from '../assets/blog-placeholder-3.jpg';
import blogImg4 from '../assets/blog-placeholder-4.jpg';
import blogImg5 from '../assets/blog-placeholder-5.jpg';
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />

<!-- ═══════════════════════════════════════════
     SECTION 1 · HERO
════════════════════════════════════════════ -->
<section id="hero" class="s-hero">
  <div class="hero-bg-pattern"></div>
  <div class="hero-inner">
    <span class="section-label">Welcome</span>
    <h1 class="hero-title">
      The <em>Polymath</em><br/>Journey
    </h1>
    <p class="hero-tagline">Where Ancient Wisdom Meets Future Intelligence</p>
    <p class="hero-name">Ch. Rupika</p>
    <p class="hero-sub">
      Namaste! I am a curious learner and explorer passionate about connecting different domains of knowledge. My journey combines technology, artificial intelligence, science, research, creativity, and problem-solving.
    </p>
    <div class="hero-btns">
      <a href="#journey" class="btn-gold">Explore My Journey</a>
      <a href="/blog"    class="btn-ghost">Read My Blog</a>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">
      <span>Scroll</span>
      <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
        <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1.5"/>
        <circle class="scroll-dot" cx="8" cy="7" r="2.5" fill="currentColor"/>
      </svg>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 2 · AREAS I EXPLORE
════════════════════════════════════════════ -->
<section id="about" class="s-about">
  <div class="section-inner">
    <span class="section-label reveal">About Me</span>
    <h2 class="section-title reveal">A Renaissance Mind</h2>
    <div class="divider-gold reveal"></div>
    <p class="section-desc reveal">
      I am currently pursuing my third year of B.Tech in Computer Science and Engineering (AI &amp; ML) at Visakha Institute of Engineering and Technology. My journey began in a spirituality-based school where ancient wisdom shaped my values, and today I stand at the intersection of technology, science, and lifelong curiosity.
    </p>
    <h3 class="interests-heading reveal">Areas I Explore</h3>
    <ul class="interests-grid">
      {[
        ['⚡','Technical Professional','48 LPA Career Goals'],
        ['🧠','Psychologist','Understanding the human mind'],
        ['📜','Philosopher','Exploring timeless wisdom'],
        ['🔭','Astrophysicist','Mysteries of the cosmos'],
        ['🕵️','RAW Enthusiast','Intelligence & research'],
        ['🔍','Crime Investigation','Analytical exploration'],
        ['🏛','Archaeology','Unearthing ancient worlds'],
        ['🛕','Temple Researcher','India\'s sacred heritage'],
        ['🎵','Singer','Expression through music'],
        ['🌐','Linguist','Languages & communication'],
        ['🏸','Badminton Player','Discipline through sport'],
        ['🏹','Archery Enthusiast','Precision & focus'],
        ['💃','Dancer','Rhythm & movement'],
        ['🏛','IAS Officer Aspirant','Public service & leadership'],
        ['📚','Professor','Sharing knowledge'],
        ['🎬','Content Creator','Storytelling for impact'],
      ].map(([icon, title, sub]) => (
        <li class="interest-card reveal glass-card">
          <span class="ic-icon">{icon}</span>
          <strong class="ic-title">{title}</strong>
          <span class="ic-sub">{sub}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 3 · BLOG JOURNEY (main hero)
════════════════════════════════════════════ -->
<section id="journey" class="s-journey">
  <div class="journey-bg"></div>
  <div class="section-inner">
    <span class="section-label reveal">My Story</span>
    <h2 class="section-title section-title--light reveal">The Polymath Journey</h2>
    <p class="section-desc section-desc--light reveal">
      Every chapter of my life is a step forward — from ancient spiritual roots to the frontiers of artificial intelligence.
    </p>
    <div class="divider-gold reveal"></div>
    <div class="journey-cards">
      {[
        { slug:'article-1-inception',     img:blogImg1, date:'Jan 2024', read:'4 min', emoji:'🏛', title:'Inception',         prev:'My journey began in a spirituality-based school where I learned about our history, culture, discipline, and integrity. At age seven, I was published in a newspaper as "Slokala Rupika."' },
        { slug:'article-2-next-chapter',  img:blogImg2, date:'Feb 2024', read:'3 min', emoji:'🎓', title:'The Next Chapter',   prev:'After 10th standard, I joined Sri Chaitanya Junior College. I learned independence, responsibility, discipline, and how to overcome challenges.' },
        { slug:'article-3-awakening',     img:blogImg3, date:'Mar 2024', read:'5 min', emoji:'💡', title:'Awakening',          prev:'By God\'s grace I received admission to Visakha Institute of Engineering and Technology. Here my curiosity about ancient temples, quantum physics, and AI awakened.' },
        { slug:'article-4-exploration',   img:blogImg4, date:'Apr 2024', read:'10 min',emoji:'🚀', title:'Exploration',        prev:'My third year became the beginning of my skill development journey — Agentic AI, modern tools, Indian Knowledge Systems, blockchain, and real-world project building.' },
        { slug:'article-5-dream-goals',   img:blogImg5, date:'May 2024', read:'3 min', emoji:'🌟', title:'Dream Goals',        prev:'My long-term aspiration is to build a successful career in technology while exploring psychology, philosophy, archaeology, astrophysics, and lifelong learning.' },
      ].map((a, i) => (
        <article class={`jcard reveal ${i === 0 ? 'jcard--featured' : ''}`}>
          <div class="jcard-img">
            <Image src={a.img} alt={a.title} width={680} height={340} loading="lazy"/>
            <span class="jcard-emoji">{a.emoji}</span>
          </div>
          <div class="jcard-body">
            <div class="jcard-meta">
              <span class="jcard-date">{a.date}</span>
              <span class="jcard-read">⏱ {a.read}</span>
            </div>
            <h3 class="jcard-title">{a.title}</h3>
            <p class="jcard-prev">{a.prev}</p>
            <a href={`/blog/${a.slug}`} class="btn-gold jcard-btn">
              Explore More
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
    <div class="journey-cta reveal">
      <a href="/blog" class="btn-ghost">View All Articles →</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 4 · TIMELINE
════════════════════════════════════════════ -->
<section id="timeline" class="s-timeline">
  <div class="section-inner">
    <span class="section-label reveal">My Path</span>
    <h2 class="section-title reveal">Learning Timeline</h2>
    <div class="divider-gold reveal"></div>
    <ol class="timeline">
      {[
        { icon:'🏫', year:'2010–2020', title:'School',                  desc:'Spirituality-based education. Learned Mahabharata, Ramayana, Bhagavad Gita. Published as "Slokala Rupika" at age 7. Above-average student through 10th standard.' },
        { icon:'📖', year:'2020–2022', title:'Intermediate',             desc:'Joined Sri Chaitanya Junior College. Developed independence, time management, discipline, and the confidence to navigate life beyond the classroom.' },
        { icon:'⚙️', year:'2022–2023', title:'Engineering · Year 1',    desc:'Entered Visakha Institute of Engineering & Technology. Participated in PPT competitions. Curiosity about ancient temples and quantum physics ignited.' },
        { icon:'🤖', year:'2023–2024', title:'Engineering · Year 2',    desc:'Discovered AI & ML. Learned heuristic search, A* algorithm, Decision Trees, Neural Networks, RNN, and participated in hackathons and ideathons.' },
        { icon:'🚀', year:'2024–Now',  title:'Engineering · Year 3',    desc:'Joined skill development program under Dr. Pallam Setti Sir & Shiva Kiran Sir. Building AI agents with n8n. Exploring Agentic AI, IKS, blockchain, and quantum physics.' },
        { icon:'🌟', year:'Future',    title:'Dream Goals',              desc:'Build a 48 LPA tech career. Explore AI, psychology, philosophy, astrophysics, archaeology, and public service. Lifelong learning and meaningful contribution.' },
      ].map((item, i) => (
        <li class="tl-item reveal">
          <div class="tl-marker">
            <span class="tl-icon">{item.icon}</span>
          </div>
          <div class="tl-content glass-card">
            <span class="tl-year">{item.year}</span>
            <h3 class="tl-title">{item.title}</h3>
            <p class="tl-desc">{item.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 5 · LEARNING PLATFORMS
════════════════════════════════════════════ -->
<section id="platforms" class="s-platforms">
  <div class="section-inner">
    <span class="section-label reveal">Resources</span>
    <h2 class="section-title reveal">Platforms That Helped Me Learn</h2>
    <div class="divider-gold reveal"></div>
    <p class="section-desc reveal">Every tool and platform below played a role in shaping my learning journey.</p>
    <div class="platforms-grid">
      {[
        { id:'replit',    icon:'💻', name:'Replit',          desc:'Online coding platform for building and testing applications from the browser. Helped me understand project development and deployment.' },
        { id:'github',    icon:'🐙', name:'GitHub',          desc:'Version control and collaboration platform. Helped me manage code, track changes, and publish projects.' },
        { id:'kiro',      icon:'🤖', name:'Kiro IDE',        desc:'AI-powered development environment that helped me understand coding, project structure, debugging, and application development.' },
        { id:'cursor',    icon:'✨', name:'Cursor',          desc:'AI-powered code editor that assists with coding, debugging, and understanding projects faster.' },
        { id:'antigrav',  icon:'🚀', name:'Antigravity',     desc:'AI-assisted development environment that simplified project creation, editing, and rapid experimentation.' },
        { id:'n8n',       icon:'⚙️', name:'n8n',            desc:'Workflow automation platform used to build AI agents and automate tasks by connecting different services.' },
        { id:'openai',    icon:'🧠', name:'OpenAI',          desc:'Advanced AI models and APIs for intelligent applications, automation, and language understanding.' },
        { id:'gemini',    icon:'♊', name:'Gemini',          desc:"Google's AI model for research, coding, reasoning, and productivity tasks." },
        { id:'glm',       icon:'💬', name:'GLM',             desc:'Large Language Model used for AI-based conversations and application development.' },
        { id:'ollama',    icon:'🦙', name:'Ollama',          desc:'Platform for running open-source AI models locally for experimentation and learning.' },
        { id:'sarvam',    icon:'🇮🇳', name:'Sarvam AI',       desc:'Indian AI platform focused on multilingual AI technologies for Indian languages.' },
        { id:'student',   icon:'🎓', name:'Student Chakra',  desc:'Student learning platform providing educational resources, opportunities, and skill development.' },
        { id:'hack2skill',icon:'🏆', name:'Hack2Skill',      desc:'Platform hosting hackathons, coding competitions, innovation challenges, and skill-building events.' },
        { id:'iks',       icon:'🕉', name:'IKS',             desc:"Platform for exploring India's traditional knowledge, culture, science, philosophy, mathematics, and heritage." },
        { id:'stemiks',   icon:'🔬', name:'STEM IKS',        desc:'Educational platform combining STEM education with Indian Knowledge Systems for interdisciplinary learning.' },
      ].map(p => (
        <button class="pcard glass-card reveal" data-platform={p.id} aria-label={`Learn more about ${p.name}`}>
          <span class="pcard-icon">{p.icon}</span>
          <strong class="pcard-name">{p.name}</strong>
          <p class="pcard-desc">{p.desc}</p>
          <span class="pcard-badge">Learning Resource</span>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 6 · TECHNOLOGIES
════════════════════════════════════════════ -->
<section id="technologies" class="s-tech">
  <div class="section-inner">
    <span class="section-label reveal">Knowledge</span>
    <h2 class="section-title reveal">Technologies &amp; Concepts I Explored</h2>
    <div class="divider-gold reveal"></div>
    <div class="tech-grid">
      {[
        { icon:'🤖', title:'Agentic AI',              desc:'AI systems that reason, plan, and execute tasks autonomously.' },
        { icon:'🧬', title:'Artificial Intelligence', desc:'Creating intelligent systems that learn and adapt.' },
        { icon:'📊', title:'Machine Learning',        desc:'Training models to recognise patterns and make predictions.' },
        { icon:'🕸', title:'Neural Networks',         desc:'Layered computational models inspired by the human brain.' },
        { icon:'🛠', title:'AI Agents',               desc:'Autonomous systems that perform tasks and make decisions.' },
        { icon:'⚙️', title:'Workflow Automation',    desc:'Connecting services and automating repetitive processes.' },
        { icon:'⛓', title:'Blockchain',              desc:'Distributed ledger technology and decentralised applications.' },
        { icon:'₿',  title:'Bitcoin',                desc:'Decentralised digital currency and cryptographic systems.' },
        { icon:'💰', title:'Cryptocurrency',          desc:'Digital assets and next-generation financial technologies.' },
        { icon:'⚛️', title:'Quantum Physics',        desc:'Exploring the fundamental nature of particles and energy.' },
        { icon:'🌌', title:'Black Holes',             desc:'Cosmic phenomena, spacetime, and gravitational singularities.' },
        { icon:'📐', title:'Richard Feynman',         desc:"Physics, curiosity, and 'the pleasure of finding things out'." },
        { icon:'🕉', title:'Panchakosha',             desc:'Ancient Indian model of five layers of human personality.' },
        { icon:'🏛', title:'Indian Knowledge Systems',desc:'Traditional wisdom in science, mathematics, and philosophy.' },
      ].map(t => (
        <div class="tcard glass-card reveal">
          <span class="tcard-icon">{t.icon}</span>
          <strong class="tcard-title">{t.title}</strong>
          <p class="tcard-desc">{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 7 · MOVIES
════════════════════════════════════════════ -->
<section id="movies" class="s-movies">
  <div class="section-inner">
    <span class="section-label reveal">Inspiration</span>
    <h2 class="section-title reveal">Movies That Inspired My Thinking</h2>
    <div class="divider-gold reveal"></div>
    <div class="media-gallery">
      {[
        { id:'inception',   emoji:'🌀', title:'Inception',        year:'2010', insight:'The power of ideas planted deep inside the mind.', why:'Inspired me to think about layers of reality, perception, and how ideas shape our actions.', takeaway:'Every dream is a step inside a deeper layer of thought.' },
        { id:'matrix',      emoji:'💊', title:'The Matrix',        year:'1999', insight:'What if reality itself is a simulation?', why:'Challenged me to question assumptions about the world and human potential.', takeaway:'The truth is only found by those willing to look beyond the surface.' },
        { id:'ironman',     emoji:'🦾', title:'Iron Man',          year:'2008', insight:'Innovation and brilliance can change everything.', why:'Inspired me to build, create, and use technology as a tool for positive change.', takeaway:'Engineering is not just a skill — it is a superpower.' },
        { id:'bigshort',    emoji:'📉', title:'The Big Short',     year:'2015', insight:'Understanding systems — financial or otherwise — is power.', why:'Taught me to think critically about complex systems and challenge conventional wisdom.', takeaway:'Those who understand the rules can see when they are being broken.' },
        { id:'startrek',    emoji:'🖖', title:'Star Trek',         year:'1966', insight:'A future built on collaboration, science, and exploration.', why:'Showed me an optimistic vision of humanity united by curiosity and technology.', takeaway:'The final frontier is the human mind.' },
        { id:'starwars',    emoji:'⚔️', title:'Star Wars',         year:'1977', insight:'Every person carries the potential for light and darkness.', why:"Taught me about resilience, mythology, and the hero's journey present in every life.", takeaway:'The force within is stronger than any circumstance without.' },
        { id:'siliconvalley',emoji:'💡',title:'Silicon Valley',    year:'2014', insight:'Building something from nothing is messy, funny, and real.', why:'Gave me a realistic view of startup culture, technology business, and problem-solving.', takeaway:'Compression is just the beginning — find your own algorithm.' },
      ].map(m => (
        <button class="mcard reveal" data-media={m.id} aria-label={`Learn about ${m.title}`}>
          <div class="mcard-poster">
            <span class="mcard-emoji">{m.emoji}</span>
          </div>
          <strong class="mcard-title">{m.title}</strong>
          <span class="mcard-year">{m.year}</span>
          <p class="mcard-insight">{m.insight}</p>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 8 · ANIME
════════════════════════════════════════════ -->
<section id="anime" class="s-anime">
  <div class="section-inner">
    <span class="section-label reveal">Inspiration</span>
    <h2 class="section-title reveal">Anime That Inspired My Thinking</h2>
    <div class="divider-gold reveal"></div>
    <div class="media-gallery media-gallery--sm">
      {[
        { id:'fmab',   emoji:'⚗️', title:'Fullmetal Alchemist: Brotherhood', year:'2009', insight:'Sacrifice, perseverance, and the cost of ambition.', why:'Showed me that true knowledge comes with responsibility, and that human connection is more powerful than any technique.', takeaway:'Equivalent exchange: to gain something, something of equal value must be lost.' },
        { id:'deathnote', emoji:'📓', title:'Death Note',  year:'2006', insight:'Power without ethics destroys even the greatest minds.', why:'Explored morality, justice, and the dangerous intersection of intelligence and hubris.', takeaway:'Genius without conscience is a weapon without direction.' },
        { id:'avatar', emoji:'🌊', title:'Avatar: The Last Airbender', year:'2005', insight:'Balance, responsibility, and the weight of purpose.', why:'Taught me that growth requires mastering not just skills but also one\'s inner world.', takeaway:'The greatest victory is the one over yourself.' },
      ].map(a => (
        <button class="mcard reveal" data-media={a.id} aria-label={`Learn about ${a.title}`}>
          <div class="mcard-poster">
            <span class="mcard-emoji">{a.emoji}</span>
          </div>
          <strong class="mcard-title">{a.title}</strong>
          <span class="mcard-year">{a.year}</span>
          <p class="mcard-insight">{a.insight}</p>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 9 · SKILLS
════════════════════════════════════════════ -->
<section id="skills" class="s-skills">
  <div class="section-inner">
    <span class="section-label reveal">Capabilities</span>
    <h2 class="section-title reveal">Skills I Developed</h2>
    <div class="divider-gold reveal"></div>
    <div class="skills-grid">
      {[
        { icon:'🗣', skill:'Communication',       level:85 },
        { icon:'🧩', skill:'Problem Solving',     level:88 },
        { icon:'🔍', skill:'Critical Thinking',   level:82 },
        { icon:'🔬', skill:'Research',            level:80 },
        { icon:'🤖', skill:'AI Development',      level:75 },
        { icon:'💻', skill:'Programming',         level:78 },
        { icon:'🐙', skill:'Git & GitHub',        level:80 },
        { icon:'⚙️', skill:'Workflow Automation', level:72 },
        { icon:'🎨', skill:'Portfolio Building',  level:85 },
        { icon:'🔄', skill:'Continuous Learning', level:95 },
        { icon:'🤝', skill:'Teamwork',            level:88 },
        { icon:'🏛', skill:'Leadership',          level:76 },
      ].map(s => (
        <div class="skill-card glass-card reveal">
          <div class="skill-top">
            <span class="skill-icon">{s.icon}</span>
            <strong class="skill-name">{s.skill}</strong>
            <span class="skill-pct">{s.level}%</span>
          </div>
          <div class="skill-bar">
            <div class="skill-fill" style={`--pct:${s.level}%`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 10 · CONTACT
════════════════════════════════════════════ -->
<section id="contact" class="s-contact">
  <div class="section-inner">
    <span class="section-label reveal">Say Hello</span>
    <h2 class="section-title reveal">Get In Touch</h2>
    <div class="divider-gold reveal"></div>
    <p class="section-desc reveal">
      I am always open to conversations about technology, ancient wisdom, AI, or simply exchanging ideas. Feel free to reach out.
    </p>
    <div class="contact-cards reveal">
      <a href="mailto:rupika@example.com" class="contact-card glass-card">
        <span class="cc-icon">✉️</span>
        <strong>Email</strong>
        <span>rupika@example.com</span>
      </a>
      <a href="https://github.com/rupika593" target="_blank" rel="noopener noreferrer" class="contact-card glass-card">
        <span class="cc-icon">🐙</span>
        <strong>GitHub</strong>
        <span>rupika593</span>
      </a>
      <a href="https://www.linkedin.com/in/rupika" target="_blank" rel="noopener noreferrer" class="contact-card glass-card">
        <span class="cc-icon">💼</span>
        <strong>LinkedIn</strong>
        <span>Ch. Rupika</span>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     MODALS — Platforms & Media
════════════════════════════════════════════ -->
<div class="modal-overlay" id="platform-modal" role="dialog" aria-modal="true" aria-labelledby="pm-title">
  <div class="modal-box">
    <button class="modal-close" id="pm-close" aria-label="Close">✕</button>
    <span class="modal-icon" id="pm-icon"></span>
    <h3 id="pm-title" class="modal-title"></h3>
    <p id="pm-desc" class="modal-desc"></p>
    <p class="modal-experience-label">My Learning Experience</p>
    <p id="pm-exp" class="modal-exp"></p>
    <a id="pm-link" href="#" target="_blank" rel="noopener noreferrer" class="btn-gold modal-btn">Visit Website →</a>
  </div>
</div>

<div class="modal-overlay" id="media-modal" role="dialog" aria-modal="true" aria-labelledby="mm-title">
  <div class="modal-box">
    <button class="modal-close" id="mm-close" aria-label="Close">✕</button>
    <div class="mm-poster" id="mm-poster"></div>
    <span class="mm-year" id="mm-year"></span>
    <h3 id="mm-title" class="modal-title"></h3>
    <p class="modal-experience-label">Why it inspired me</p>
    <p id="mm-why" class="modal-desc"></p>
    <p class="modal-experience-label">Key Takeaway</p>
    <p id="mm-takeaway" class="modal-exp"></p>
  </div>
</div>

<Footer />
</body>

<style>
/* ── Shared Section Layout ── */
.section-inner{max-width:1200px;margin:0 auto;padding:var(--section-pad);text-align:center;}
.section-title{font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);color:var(--charcoal);margin:.6rem 0 1.4rem;}
.section-title--light{color:#fff;}
.section-desc{max-width:680px;margin:0 auto 2.5rem;color:var(--slate);font-size:1.05rem;line-height:1.8;}
.section-desc--light{color:rgba(255,255,255,0.85);}

/* ── HERO ── */
.s-hero{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  background:linear-gradient(145deg,var(--charcoal) 0%,#2D2D30 40%,#1a1a2e 100%);
  position:relative;overflow:hidden;padding:6rem 2rem 4rem;text-align:center;
}
.hero-bg-pattern{
  position:absolute;inset:0;
  background-image:radial-gradient(circle at 20% 40%,rgba(201,168,76,.12) 0,transparent 55%),
    radial-gradient(circle at 80% 70%,rgba(201,168,76,.08) 0,transparent 45%),
    radial-gradient(1.5px 1.5px at 15% 20%,rgba(255,255,255,.7) 0,transparent 0),
    radial-gradient(1px 1px at 40% 60%,rgba(201,168,76,.9) 0,transparent 0),
    radial-gradient(1.5px 1.5px at 65% 30%,rgba(255,255,255,.5) 0,transparent 0),
    radial-gradient(1px 1px at 85% 50%,rgba(201,168,76,.7) 0,transparent 0),
    radial-gradient(1px 1px at 30% 80%,rgba(255,255,255,.4) 0,transparent 0);
  background-size:100% 100%,100% 100%,200px 200px,300px 300px,250px 250px,220px 220px,180px 180px;
  animation:hero-stars 12s ease-in-out infinite alternate;pointer-events:none;
}
@keyframes hero-stars{0%{opacity:.7}100%{opacity:1}}
.hero-inner{position:relative;z-index:1;max-width:820px;width:100%;}
.hero-title{
  font-family:var(--font-display);font-size:clamp(3.2rem,8vw,6.5rem);
  font-weight:900;line-height:1.05;color:#fff;margin:1rem 0 1.2rem;
  text-shadow:0 4px 40px rgba(0,0,0,.4);
}
.hero-title em{
  font-style:normal;
  background:linear-gradient(135deg,var(--gold-dark),var(--gold-light),var(--gold-dark));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  background-size:200% auto;animation:gold-flow 4s linear infinite;
}
@keyframes gold-flow{0%{background-position:0%}100%{background-position:200%}}
.hero-tagline{font-family:var(--font-display);font-style:italic;font-size:clamp(1rem,2.5vw,1.4rem);color:rgba(255,255,255,.75);margin-bottom:.75rem;letter-spacing:.02em;}
.hero-name{font-family:var(--font-body);font-size:1.1rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--gold-light);margin-bottom:1.8rem;}
.hero-sub{font-size:1.05rem;color:rgba(255,255,255,.7);max-width:600px;margin:0 auto 2.5rem;line-height:1.8;}
.hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem;}
.hero-scroll-hint{display:flex;flex-direction:column;align-items:center;gap:.5rem;color:rgba(255,255,255,.35);font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;}
.scroll-dot{animation:scroll-bounce 2s ease-in-out infinite;}
@keyframes scroll-bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}

/* ── ABOUT / INTERESTS ── */
.s-about{background:var(--warm-white);padding:0;}
.interests-heading{font-family:var(--font-display);font-size:1.8rem;color:var(--charcoal);margin:0 0 1.8rem;}
.interests-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:1rem;list-style:none;padding:0;margin:0;text-align:left;
}
.interest-card{display:flex;flex-direction:column;gap:.3rem;padding:1.2rem 1.4rem;cursor:default;}
.ic-icon{font-size:1.6rem;line-height:1;}
.ic-title{font-family:var(--font-body);font-size:.9rem;font-weight:700;color:var(--charcoal);}
.ic-sub{font-size:.8rem;color:var(--slate);}
</style>

<style>
/* ── JOURNEY (Blog) ── */
.s-journey{background:linear-gradient(160deg,#0F172A 0%,#1E3A5F 50%,#1a1a2e 100%);padding:0;position:relative;overflow:hidden;}
.journey-bg{position:absolute;inset:0;background:radial-gradient(circle at 70% 30%,rgba(201,168,76,.08) 0,transparent 55%),radial-gradient(circle at 20% 80%,rgba(6,182,212,.06) 0,transparent 50%);pointer-events:none;}
.journey-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:2rem;margin-top:2rem;text-align:left;}
.jcard{background:rgba(255,254,249,.04);border:1px solid rgba(201,168,76,.18);border-radius:20px;overflow:hidden;transition:all .4s var(--ease-out);}
.jcard:hover{transform:translateY(-10px);box-shadow:0 20px 60px rgba(0,0,0,.35),0 0 0 1px rgba(201,168,76,.35);}
.jcard--featured{grid-column:1/-1;}
.jcard-img{position:relative;overflow:hidden;}
.jcard-img img{width:100%;height:220px;object-fit:cover;transition:transform .5s ease;display:block;}
